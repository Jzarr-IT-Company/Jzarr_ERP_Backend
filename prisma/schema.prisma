generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum Role {
  SUPER_ADMIN
  SUB_ADMIN
  MANAGER
}

model User {
  id       Int    @id @default(autoincrement())
  name     String
  email    String @unique
  password String

  role Role

  createdBy Int?
  creator   User?  @relation("UserCreator", fields: [createdBy], references: [id])
  managers  User[] @relation("UserCreator")

  logs ActivityLog[]

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  contracts         Contract[]
  contractRevisions ContractRevision[]
  grantedContracts  Contract[]         @relation("GrantedBy")
}

model Contract {
  id          Int     @id @default(autoincrement())
  title       String
  description String?

  managerId Int
  manager   User @relation(fields: [managerId], references: [id])

  editGranted Boolean @default(false)

  grantedById Int?
  grantedBy   User? @relation(fields: [grantedById], references: [id], name: "GrantedBy")

  grantedAt DateTime?

  revisions ContractRevision[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContractRevision {
  id Int @id @default(autoincrement())

  contractId Int
  contract   Contract @relation(fields: [contractId], references: [id])

  changedById Int
  changedBy   User @relation(fields: [changedById], references: [id])

  oldData Json
  newData Json

  createdAt DateTime @default(now())
}

model ActivityLog {
  id Int @id @default(autoincrement())

  userId Int
  user   User @relation(fields: [userId], references: [id])

  action   String
  entity   String
  entityId Int?

  createdAt DateTime @default(now())
}
