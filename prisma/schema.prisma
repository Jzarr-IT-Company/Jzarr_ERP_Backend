generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum ENUM_ROLE {
  SUPER_ADMIN
  SUB_ADMIN
  MANAGER
}

model User {
  id          Int       @id @default(autoincrement())
  name        String
  email       String    @unique
  password    String
  role        ENUM_ROLE
  createdById Int?

  createdBy    User?  @relation("UserCreator", fields: [createdById], references: [id])
  createdUsers User[] @relation("UserCreator")

  contracts Contract[]

  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  contractEditPermissions ContractEditPermission[]
  clients                 Client[]
}

enum ApprovalStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Contract {
  id          Int    @id @default(autoincrement())
  title       String
  description String
  managerId   Int

  subAdminStatus   ApprovalStatus @default(PENDING)
  superAdminStatus ApprovalStatus @default(PENDING)

  manager User @relation(fields: [managerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  editPermissions ContractEditPermission[]
  client          Client                   @relation(fields: [clientId], references: [id])
  clientId        Int

  @@index([clientId])
  @@index([managerId])
}

model ContractEditPermission {
  id         Int @id @default(autoincrement())
  contractId Int
  managerId  Int

  expiresAt DateTime
  clientId  Int
  client    Client   @relation(fields: [clientId], references: [id])

  contract Contract @relation(fields: [contractId], references: [id])
  manager  User     @relation(fields: [managerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Client {
  id      Int    @id @default(autoincrement())
  name    String
  phone   String
  address String

  createdById             Int?
  createdBy               User?                    @relation(fields: [createdById], references: [id], onDelete:SetNull)
  contracts               Contract[]
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  contractEditPermissions ContractEditPermission[]

  @@index([createdById])
}



